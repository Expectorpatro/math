# Generated HTML is ignored by default.  The committed static site and the
# hand-authored HTML behaviour layers are explicit exceptions.
*.html
!html/theme-toggle.html
!html/density-plots.html
!html/formula-copy.html
!html/site/*.html
!html/site/**/*.html
!**/computations/**/result.html

